{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "System",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "System ID"
    },
    "name": {
      "type": "string",
      "description": "System name"
    },
    "last_event_at": {
      "type": "string"
    },
    "auto_delete": {
      "type": "boolean"
    },
    "ip_address": {
      "type": "string"
    },
    "hostname": {
      "type": "string"
    },
    "syslog": {
      "type": "object"
    }
  }
}